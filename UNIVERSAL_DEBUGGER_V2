-- ==========================================
-- CLICK ENGINE
-- ==========================================
local detectedMethod = nil
local function FireButton(button)
	pcall(function() button.Active = true end)
	local method = "none"

	if typeof(getconnections) == "function" then
		local fired = false
		pcall(function()
			for _, c in ipairs(getconnections(button.MouseButton1Down)) do
				task.spawn(function() pcall(function() c:Fire() end) end)
				fired = true
			end
			task.wait(0.04)
			for _, c in ipairs(getconnections(button.Activated)) do
				task.spawn(function() pcall(function() c:Fire() end) end)
				fired = true
			end
			for _, c in ipairs(getconnections(button.MouseButton1Click)) do
				task.spawn(function() pcall(function() c:Fire() end) end)
			end
		end)
		if fired then method = "getconn" end
	end

	if method == "none" and typeof(firesignal) == "function" then
		pcall(function()
			firesignal(button.MouseButton1Down)
			task.wait(0.04)
			firesignal(button.Activated)
			firesignal(button.MouseButton1Click)
		end)
		method = "firesignal"
	end

	if method == "none" and typeof(firebutton) == "function" then
		pcall(function() firebutton(button, "") end)
		method = "firebutton"
	end

	if method == "none" then
		local ok, pos = pcall(function() return button.AbsolutePosition end)
		if ok then
			local size = button.AbsoluteSize
			local inset = GuiService:GetGuiInset()
			local x = pos.X + size.X / 2
			local y = pos.Y + size.Y / 2 + inset.Y
			pcall(function()
				VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
				task.wait(0.05)
				VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
			end)
			method = "VIM"
		end
	end

	pcall(function() button.Active = false end)
	detectedMethod = method
	MethodLbl.Text = "🔌 Click method: " .. method
	return method
end

-- ==========================================
-- SPY & SCAN ENGINE
-- ==========================================
local function SpyElement(obj, prefix)
	prefix = prefix or ""
	local signals = {
		"MouseButton1Click","MouseButton1Down","MouseButton1Up",
		"Activated","InputBegan","InputEnded","MouseEnter","TouchTap"
	}
	local hasAny = false
	if typeof(getconnections) == "function" then
		for _, sig in ipairs(signals) do
			pcall(function()
				local conns = getconnections(obj[sig])
				if #conns > 0 then
					AddLog(prefix.."["..sig.."] "..#conns.." conn(s)", Color3.fromRGB(140,220,255))
					hasAny = true
				end
			end)
		end
	end
	if not hasAny then
		AddLog(prefix.."no signals found (Active="..tostring(obj.Active)..")", Color3.fromRGB(180,100,100))
	end
end

local function DeepScan(root, depth)
	depth = depth or 0
	if depth > 8 then return end
	local results = {images={}, buttons={}}

	local function check(obj)
		if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
			if obj.Image ~= "" then
				table.insert(results.images, {obj=obj, img=obj.Image, vis=obj.Visible})
				IdLbl.Text = "🖼 " .. obj.Image
			end
		end
		if obj:IsA("ImageButton") or obj:IsA("TextButton") then
			table.insert(results.buttons, obj)
		end
	end

	check(root)
	for _, d in ipairs(root:GetDescendants()) do check(d) end
	return results
end

local function DumpObject(obj, indent)
	indent = indent or 0
	local pad = string.rep("  ", indent)
	local info = obj.ClassName .. " '" .. obj.Name .. "'"

	if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
		info = info .. " img=[" .. obj.Image .. "] vis=" .. tostring(obj.Visible)
	elseif obj:IsA("TextLabel") or obj:IsA("TextButton") then
		info = info .. " txt=[" .. obj.Text .. "]"
	end

	AddLog(pad .. info, Color3.fromRGB(160, 160, 100))

	if indent < 5 then
		for _, child in ipairs(obj:GetChildren()) do
			DumpObject(child, indent + 1)
		end
	end
end

local function ProcessElement(obj, parentGui)
	if not isActive or not obj or not obj.Parent then return end
	local results = DeepScan(obj)
	if not results then return end

	totalSeen += 1
	SeenLbl.Text = "👁 Seen: " .. totalSeen

	for _, imgData in ipairs(results.images) do
		local imgId = imgData.img
		AddLog("[img] " .. imgId .. " vis=" .. tostring(imgData.vis), Color3.fromRGB(100, 160, 255))
	end

	if autoClickEnabled and InputBox.Text ~= "" then
		local targetId = InputBox.Text:match("rbxassetid://%d+") or InputBox.Text
		for _, imgData in ipairs(results.images) do
			if imgData.img == targetId and imgData.vis then
				local button = nil
				if obj:IsA("ImageButton") or obj:IsA("TextButton") then
					button = obj
				else
					for _, b in ipairs(results.buttons) do
						if b.Visible then button = b; break end
					end
					if not button then button = obj end
				end

				MakeDot(obj, Color3.fromRGB(50, 255, 50), "CLICK")
				local method = FireButton(button)
				totalClicked += 1
				ClickedLbl.Text = "✅ Clicked: " .. totalClicked
				AddLog("[CLICK] " .. obj.Name .. " via " .. method, Color3.fromRGB(80, 255, 120))
				SetStatus("✅ Clicked! #"..totalClicked, 15, 50, 20)
				return
			end
		end
	end

	for _, btn in ipairs(results.buttons) do
		local sigCount = 0
		if typeof(getconnections) == "function" then
			for _, sig in ipairs({"Activated","MouseButton1Click","MouseButton1Down"}) do
				pcall(function() sigCount += #getconnections(btn[sig]) end)
			end
		end
		if sigCount > 0 then
			AddLog("[btn] " .. btn.Name .. " (" .. btn.ClassName .. ") signals=" .. sigCount .. " active=" .. tostring(btn.Active),
				Color3.fromRGB(255, 200, 80))
		end
	end
end

-- ==========================================
-- HOOKS
-- ==========================================
local function HookFrame(frame, guiName)
	AddLog("[hook] " .. guiName .. " > " .. frame.Name, Color3.fromRGB(100, 180, 255))

	for _, child in ipairs(frame:GetChildren()) do
		task.spawn(function()
			task.wait(0.03)
			ProcessElement(child, guiName)
		end)
	end

	local conn = frame.ChildAdded:Connect(function(child)
		task.spawn(function()
			task.wait(0.03)
			ProcessElement(child, guiName)
		end)
	end)
	table.insert(connections, conn)

	local conn2 = frame.DescendantAdded:Connect(function(desc)
		if desc:IsA("ImageLabel") or desc:IsA("ImageButton") then
			if desc.Image ~= "" then
				IdLbl.Text = "🖼 " .. desc.Image
				AddLog("[desc] " .. desc.Image, Color3.fromRGB(160, 120, 255))
			end
		end
	end)
	table.insert(connections, conn2)
end

local function HookGui(gui)
	if watchedGuis[gui] then return end
	watchedGuis[gui] = true

	local hookedAny = false
	for _, child in ipairs(gui:GetChildren()) do
		if child:IsA("Frame") or child:IsA("ScrollingFrame") then
			HookFrame(child, gui.Name)
			hookedAny = true
		end
	end
	if not hookedAny then
		local conn = gui.ChildAdded:Connect(function(child)
			task.spawn(function()
				task.wait(0.1)
				if child:IsA("Frame") or child:IsA("ScrollingFrame") then
					HookFrame(child, gui.Name)
				else
					ProcessElement(child, gui.Name)
				end
			end)
		end)
		table.insert(connections, conn)
	end

	local conn = gui.ChildAdded:Connect(function(child)
		if child:IsA("Frame") or child:IsA("ScrollingFrame") then
			HookFrame(child, gui.Name)
		end
	end)
	table.insert(connections, conn)
end

