local function MakeDot(target, color, label)
	if not target then return end
	local ok, pos = pcall(function() return target.AbsolutePosition end)
	if not ok then return end
	local size = target.AbsoluteSize
	local inset = GuiService:GetGuiInset()
	local x = pos.X + size.X / 2
	local y = pos.Y + size.Y / 2 + inset.Y

	local dot = Instance.new("Frame")
	dot.Size = UDim2.new(0, 18, 0, 18)
	dot.AnchorPoint = Vector2.new(0.5, 0.5)
	dot.Position = UDim2.new(0, x, 0, y)
	dot.BackgroundColor3 = color
	dot.ZIndex = 20
	dot.BorderSizePixel = 0
	pcall(function() dot.Active = false end)
	Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
	dot.Parent = dotsGui

	if label then
		local lbl = Instance.new("TextLabel", dot)
		lbl.Size = UDim2.new(0, 60, 0, 14)
		lbl.Position = UDim2.new(1, 4, 0.5, -7)
		lbl.BackgroundColor3 = Color3.fromRGB(0,0,0)
		lbl.BackgroundTransparency = 0.4
		lbl.TextColor3 = Color3.fromRGB(255,255,255)
		lbl.Font = Enum.Font.Code
		lbl.TextSize = 9
		lbl.Text = label
		lbl.TextXAlignment = Enum.TextXAlignment.Left
		Instance.new("UICorner", lbl).CornerRadius = UDim.new(0, 3)
	end

	task.delay(2, function() if dot and dot.Parent then dot:Destroy() end end)
	return x, y
end

