-- Hook __namecall untuk menangkap FireServer / InvokeServer
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local method = getnamecallmethod()
    if (method == "FireServer" or method == "InvokeServer") then
        -- Cek apakah remote ini target
        local shouldLog = false
        if CONFIG.FILTER_REMOTE_BY_NAME then
            if self.Name == CONFIG.TARGET_REMOTE_NAME or CONFIG.TARGET_REMOTE_NAME == "*" then
                shouldLog = true
            end
        else
            shouldLog = true
        end

        if shouldLog then
            local args = {...}
            print(string.format("\n[📤] Client → Server (%s) Remote: %s", method, self.Name))
            print("  Args count: " .. #args)

            local stockId = nil
            for i, arg in ipairs(args) do
                local vtype = typeof(arg)
                if vtype == "buffer" then
                    dissectBuffer(arg, i)
                    if CONFIG.EXTRACT_STOCK_FROM_BUFFER then
                        stockId = tryExtractStockIdFromArg(arg) or stockId
                    end
                elseif vtype == "string" then
                    print(string.format("  Arg[%d] (string): %s", i, arg))
                    if CONFIG.EXTRACT_STOCK_FROM_STRING then
                        stockId = tryExtractStockIdFromArg(arg) or stockId
                    end
                elseif vtype == "table" then
                    print(string.format("  Arg[%d] Table:", i))
                    inspectTable(arg, 0, "  │ ")
                    if CONFIG.EXTRACT_STOCK_FROM_TABLE then
                        stockId = tryExtractStockIdFromArg(arg) or stockId
                    end
                else
                    print(string.format("  Arg[%d] (%s): %s", i, vtype, tostring(arg)))
                end
            end

            if stockId then
                print("[🔍] Stock ID ditemukan di request client: " .. stockId)
            end
        end
    end
    return oldNamecall(self, ...)
end))

-- ========================[ HOOK UI CLICKS ]========================

local function hookUI(btn)
    if not CONFIG.LOG_UI_CLICKS then return end
    if btn:IsA("GuiButton") then
        btn.MouseButton1Click:Connect(function()
            print("\n[🖱️] UI Click: " .. btn:GetFullName())
        end)
    end
end

local function hookAllUI()
    local pg = LP:WaitForChild("PlayerGui")
    for _, ui in ipairs(pg:GetDescendants()) do
        hookUI(ui)
    end
    pg.DescendantAdded:Connect(hookUI)
end

-- ========================[ INIT REMOTES ]==========================

local function hookAllRemotes()
    local remotes = {}
    -- Cari di ReplicatedStorage
    for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
            remotes[#remotes + 1] = obj
        end
    end
    -- Opsional: tambahkan workspace atau lainnya jika perlu
    -- for _, obj in ipairs(game:GetDescendants()) do ... end

    print(string.format("[*] Menemukan %d Remote", #remotes))

    for _, remote in ipairs(remotes) do
        local shouldHook = false
        if CONFIG.FILTER_REMOTE_BY_NAME then
            if remote.Name == CONFIG.TARGET_REMOTE_NAME or CONFIG.TARGET_REMOTE_NAME == "*" then
                shouldHook = true
            end
        else
            shouldHook = true
        end
        if shouldHook then
            hookOnClientEvent(remote)
        end
    end
end

