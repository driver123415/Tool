-- ==========================================
-- LOGIKA REPEAT CLICK (SMART TARGET + CALIBRATION)
-- ==========================================
RepeatBtn.MouseButton1Click:Connect(function()
    if #lastClickedObjects == 0 then
        flashButton(RepeatBtn, "No UI Scanned!", Color3.fromRGB(200, 80, 80))
        return
    end

    local targetBtn = nil
    local smallestArea = math.huge

    for _, obj in ipairs(lastClickedObjects) do
        if obj:IsA("GuiButton") and obj.Parent then
            local area = obj.AbsoluteSize.X * obj.AbsoluteSize.Y
            if area < smallestArea then
                smallestArea = area
                targetBtn = obj
            end
        end
    end

    if targetBtn then
        lastValidPath = getFullPath(targetBtn)
        local absPos = targetBtn.AbsolutePosition
        local absSize = targetBtn.AbsoluteSize
        
        local insetX, insetY = 0, 0
        local screenGui = targetBtn:FindFirstAncestorOfClass("ScreenGui")
        
        if screenGui and not screenGui.IgnoreGuiInset then
            local insetTopLeft = GuiService:GetGuiInset()
            insetX = insetTopLeft.X
            insetY = insetTopLeft.Y
        end
        
        -- Kalkulasi posisi tengah + DITAMBAH OFFSET MANUAL
        local centerX = absPos.X + (absSize.X / 2) + insetX
        local centerY = absPos.Y + (absSize.Y / 2) + insetY + vimYOffset

        -- 1. Spawn Red Dot Visualizer
        createRedDot(centerX, centerY)

        -- 2. Simulasi Klik
        VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, true, game, 1) 
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, false, game, 1) 
        
        flashButton(RepeatBtn, "VIM Clicked!", Color3.fromRGB(50, 200, 50))
    else
        flashButton(RepeatBtn, "No Button!", Color3.fromRGB(200, 80, 80))
    end
end)

CopyRealBtn.MouseButton1Click:Connect(function()
    if lastValidPath ~= "" and pcall(function() setclipboard(lastValidPath) end) then
        flashButton(CopyRealBtn, "Real Path Copied!", Color3.fromRGB(50, 200, 50))
    else
        flashButton(CopyRealBtn, "Repeat Click First!", Color3.fromRGB(200, 80, 80))
    end
end)

