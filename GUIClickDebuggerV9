local function flashButton(btn, text, color)
    task.spawn(function()
        local oriColor = btn.BackgroundColor3
        local oriText = btn.Text
        btn.BackgroundColor3 = color or Color3.fromRGB(50, 200, 50)
        btn.Text = text
        task.wait(1.5)
        btn.BackgroundColor3 = oriColor
        btn.Text = oriText
    end)
end

