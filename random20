        rootPart.CFrame = targetCFrame
        task.wait(0.05)
    else
        local speed = player:GetAttribute("KM_MAX_PLAYER_SPEED") or 16
        local distance = (rootPart.Position - targetCFrame.Position).Magnitude
        local duration = distance / (speed * Config.Pickup.TweenSpeed)
        if duration <= 0 then duration = 0.1 end
        local tween = TweenService:Create(rootPart, TweenInfo.new(duration, Enum.EasingStyle.Linear), { CFrame = targetCFrame })
        tween:Play()
        tween.Completed:Wait()
    end
    Workspace.Gravity = originalGravity
end

local isItemAuraActive = false
local function executePickup()
    if not Config.Pickup.Enable then return end
    local map = getMap()
    if not map then return end

    isItemAuraActive = true
    task.spawn(function()
        while isItemAuraActive do
            local mapData = getMap()
            local rp = getRootPart()
            if mapData and rp and mapData:FindFirstChild("Items") then
                for _, item in pairs(mapData.Items:GetChildren()) do
                    if not isIgnored(item.Name) and not item:GetAttribute("BlacklistLimbo") then
                        local pPart = item:FindFirstChild("Prompt")
                        if pPart and pPart:FindFirstChild("ProximityPrompt") and pPart.ProximityPrompt.Enabled then
                            if (pPart.Position - rp.Position).Magnitude <= Config.Pickup.AuraRange then
                                interactWithPrompt(pPart.ProximityPrompt)
                            end
                        end
                    end
                end
            end
            task.wait(0.1)
        end
    end)
    
    local maxLoops = 8 
    local currentLoop = 1
    local hasCleanedAll = false

    while currentLoop <= maxLoops and not hasCleanedAll do
        local itemsFolder = map:FindFirstChild("Items")
        if not itemsFolder then break end
        
        local priorityItems, normalItems = {}, {}
        for _, item in ipairs(itemsFolder:GetChildren()) do
            if item:IsA("Model") and not isIgnored(item.Name) and not item:GetAttribute("BlacklistLimbo") then
                if isPriority(item.Name) or isSecondPriority(item.Name) then table.insert(priorityItems, item)
                else table.insert(normalItems, item) end
            end
        end

        if #priorityItems == 0 and #normalItems == 0 then
            hasCleanedAll = true
            break
        end

        local itemsToProcess = (#priorityItems > 0) and priorityItems or normalItems
        local rp = getRootPart()
        
        if rp then
            table.sort(itemsToProcess, function(a, b)
                return (rp.Position - a:GetPivot().Position).Magnitude < (rp.Position - b:GetPivot().Position).Magnitude
            end)
        end

        for _, item in ipairs(itemsToProcess) do
            local currentRoot = getRootPart()
            if not currentRoot then break end
            
            if item and item.Parent and not isIgnored(item.Name) and not item:GetAttribute("BlacklistLimbo") then
                if isThreatened(currentRoot.Position, Config.Teleport.SafeRadius) then
                    local safePos = getSafePlaceCFrame()
                    if safePos then teleportplr(safePos) else teleportplr(currentRoot.CFrame * CFrame.new(0, 50, 0)) end 
                    task.wait(1)
                    break
                end

                local targetCFrame = item:GetPivot() * CFrame.new(0, -2.5, 0)
                moveToPositionItem(targetCFrame)
                task.wait(0.15)
                
                local pPart = item:FindFirstChild("Prompt")
                if pPart and pPart:FindFirstChild("ProximityPrompt") and pPart.ProximityPrompt.Enabled then 
                    interactWithPrompt(pPart.ProximityPrompt) 
                end
                
                local timeout = 15 
                local interrupted = false
                while item.Parent and timeout > 0 do
                    currentRoot = getRootPart()
                    if currentRoot and isThreatened(currentRoot.Position, Config.Teleport.SafeRadius) then
                        interrupted = true
                        break
                    end
                    task.wait(0.1)
                    timeout = timeout - 1
                end

                if interrupted then
                    local safePos = getSafePlaceCFrame()
                    if safePos then teleportplr(safePos) else teleportplr(currentRoot.CFrame * CFrame.new(0, 50, 0)) end
                    task.wait(1)
                    break
                end
                
                if item.Parent and not isPriority(item.Name) then
                    item:SetAttribute("BlacklistLimbo", true)
                end
            end
        end
        currentLoop = currentLoop + 1
        task.wait(0.5) 
    end
    isItemAuraActive = false
end

