    if char then return char:FindFirstChild("HumanoidRootPart") end
    return nil
end

local function getMap()
    return Workspace:FindFirstChild("CurrentRoom") and Workspace.CurrentRoom:FindFirstChildWhichIsA("Model")
end

local function getModelCenter(model)
    if not model or not model:IsA("Model") then return nil end
    local parts = {}
    for _, part in pairs(model:GetDescendants()) do
        if part:IsA("BasePart") then table.insert(parts, part) end
    end
    if #parts == 0 then return nil end
    local totalPos = Vector3.zero
    for _, part in pairs(parts) do totalPos = totalPos + part.Position end
    return totalPos / #parts
end

local function getSafePlaceCFrame()
    local elevators = Workspace:FindFirstChild("Elevators")
    if elevators then
        for _, el in ipairs(elevators:GetChildren()) do
            if el.Name == "Elevator" and el:IsA("Model") then
                local dandyStore = el:FindFirstChild("DandyStore")
                if dandyStore then
                    local dandyShop = dandyStore:FindFirstChild("DandyShop")
                    if dandyShop then
                        local root = dandyShop:FindFirstChild("RootPart")
                        if root then return root.CFrame * CFrame.new(0, 3, 0) end
                    end
                end
            end
        end
    end
    local map = getMap()
    if map then
        local freeArea = map:FindFirstChild("FreeArea")
        if freeArea then
            local fakeElevator = freeArea:FindFirstChild("FakeElevator")
            if fakeElevator and fakeElevator:IsA("Model") then 
                local center = getModelCenter(fakeElevator)
                if center then return CFrame.new(center) end
            end
        end
    end
    return nil
end

local function getRealElevatorCFrame()
    local elevatorsFolder = Workspace:FindFirstChild("Elevators")
    if elevatorsFolder then
        for _, obj in ipairs(elevatorsFolder:GetChildren()) do
            if obj.Name == "Elevator" and obj:IsA("Model") then
                if obj.PrimaryPart then return obj.PrimaryPart.CFrame * CFrame.new(0, 3, 0)
                else
                    local centerPos = getModelCenter(obj)
                    if centerPos then return CFrame.new(centerPos) * CFrame.new(0, 3, 0) end
                end
            end
        end
        for _, obj in ipairs(elevatorsFolder:GetDescendants()) do
            if obj.Name == "ElevatorPrompt" and obj:IsA("BasePart") then return obj.CFrame * CFrame.new(0, 1.5, 2) end
        end
    end
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj.Name == "ElevatorPrompt" and obj:IsA("BasePart") then
            local parentName = string.lower(obj.Parent and obj.Parent.Name or "")
            if not string.find(parentName, "fake") then return obj.CFrame * CFrame.new(0, 1.5, 2) end
        end
    end
    return nil
end

