-- ==========================================
-- LOGIKA KLIK & COPY GENERATOR
-- ==========================================
RepeatBtn.MouseButton1Click:Connect(function()
    if #lastClickedObjects == 0 then
        flashButton(RepeatBtn, "No UI Scanned!", Color3.fromRGB(200, 80, 80))
        return
    end

    local targetBtn = nil
    local smallestArea = math.huge

    for _, obj in ipairs(lastClickedObjects) do
        if obj:IsA("GuiButton") and obj.Parent then
            local area = obj.AbsoluteSize.X * obj.AbsoluteSize.Y
            if area < smallestArea then
                smallestArea = area
                targetBtn = obj
            end
        end
    end

    if targetBtn then
        if lastValidPath == "" then lastValidPath = getFullPath(targetBtn) end
        
        local absPos = targetBtn.AbsolutePosition
        local absSize = targetBtn.AbsoluteSize
        
        local insetX, insetY = 0, 0
        local screenGui = targetBtn:FindFirstAncestorOfClass("ScreenGui")
        
        if screenGui and not screenGui.IgnoreGuiInset then
            local insetTopLeft = GuiService:GetGuiInset()
            insetX, insetY = insetTopLeft.X, insetTopLeft.Y
        end
        
        local centerX = absPos.X + (absSize.X / 2) + insetX + vimXOffset
        local centerY = absPos.Y + (absSize.Y / 2) + insetY + vimYOffset

        createRedDot(centerX, centerY)
        VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, true, game, 1) 
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, false, game, 1) 
        
        flashButton(RepeatBtn, "VIM Clicked!", Color3.fromRGB(50, 200, 50))
    else
        flashButton(RepeatBtn, "No Button!", Color3.fromRGB(200, 80, 80))
    end
end)

CopyVIMBtn.MouseButton1Click:Connect(function()
    if lastValidPath == "" then
        flashButton(CopyVIMBtn, "SCAN/SET TARGET FIRST!", Color3.fromRGB(200, 80, 80))
        return
    end

    -- SCRIPT HASIL GENERATE SUDAH BUG-FREE
    local finalScript = string.format([[
-- === GENERATED VIM AUTO-CLICK SCRIPT ===
local VirtualInputManager = game:GetService("VirtualInputManager")
local GuiService = game:GetService("GuiService")

local function AutoClickUI(buttonObj, offsetX, offsetY)
    if not buttonObj or not buttonObj.Parent then 
        warn("Tombol tidak ditemukan / belum di-render!")
        return 
    end
    
    local screenGui = buttonObj:FindFirstAncestorOfClass("ScreenGui")
    local insetX, insetY = 0, 0
    if screenGui and not screenGui.IgnoreGuiInset then
        local insetTopLeft = GuiService:GetGuiInset()
        insetX, insetY = insetTopLeft.X, insetTopLeft.Y
    end
    
    local centerX = buttonObj.AbsolutePosition.X + (buttonObj.AbsoluteSize.X / 2) + insetX + offsetX
    local centerY = buttonObj.AbsolutePosition.Y + (buttonObj.AbsoluteSize.Y / 2) + insetY + offsetY

    VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, true, game, 1)
    task.wait(0.05)
    VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, false, game, 1)
end

-- Eksekusi Klik (Universal Path)
local targetBtn = %s
AutoClickUI(targetBtn, %d, %d)
]], lastValidPath, vimXOffset, vimYOffset)

    if pcall(function() setclipboard(finalScript) end) then
        flashButton(CopyVIMBtn, "SCRIPT COPIED TO CLIPBOARD!", Color3.fromRGB(50, 200, 50))
    end
end)

