-- LOGIKA GET FULL PATH YANG SUDAH DI-FIX (ANTI-HARDCODE NAMA AKUN)
local function getFullPath(obj)
    local path = obj.Name
    local current = obj.Parent
    while current and current ~= game do
        -- Jika ia mencapai objek LocalPlayer kamu (misal: dandilur123)
        if current == player then
            -- Otomatis ubah menjadi kode universal
            path = 'game:GetService("Players").LocalPlayer.' .. path
            break -- Hentikan pencarian ke atas
        end
        
        if string.match(current.Name, "%s") then
            path = '["' .. current.Name .. '"].' .. path
        else
            path = current.Name .. "." .. path
        end
        current = current.Parent
    end
    return path
end

