local isScanning = false
local allResultsData = ""
local lastScanX, lastScanY = 0, 0

ToggleScannerBtn.MouseButton1Click:Connect(function()
    isScanning = not isScanning
    ToggleScannerBtn.Text = isScanning and "Scanner Status: ON (Click UI now!)" or "Scanner Status: OFF"
    ToggleScannerBtn.BackgroundColor3 = isScanning and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(200, 80, 80)
end)

local function flashButton(btn, text, color)
    task.spawn(function()
        local oriColor, oriText = btn.BackgroundColor3, btn.Text
        btn.BackgroundColor3 = color or Color3.fromRGB(50, 200, 50)
        btn.Text = text
        task.wait(1.5)
        btn.BackgroundColor3, btn.Text = oriColor, oriText
    end)
end

ClearBtn.MouseButton1Click:Connect(function()
    allResultsData, lastScanX, lastScanY = "", 0, 0
    for _, child in ipairs(ResultsScroll:GetChildren()) do if child:IsA("Frame") then child:Destroy() end end
    flashButton(ClearBtn, "Cleared!", Color3.fromRGB(100, 100, 100))
end)

CopyAllBtn.MouseButton1Click:Connect(function()
    if allResultsData ~= "" and pcall(function() setclipboard(allResultsData) end) then
        flashButton(CopyAllBtn, "All Paths Copied!", Color3.fromRGB(50, 200, 50))
    end
end)

local function getFullPath(obj)
    local path = obj.Name
    local current = obj.Parent
    while current and current ~= game do
        path = string.match(current.Name, "%s") and '["' .. current.Name .. '"].' .. path or current.Name .. "." .. path
        current = current.Parent
    end
    return path
end

local function createResultFrame(layerNum, obj)
    local fullPathText = getFullPath(obj)
    allResultsData = allResultsData .. "Layer " .. layerNum .. " [" .. obj.ClassName .. "]: " .. obj.Name .. "\nPath: " .. fullPathText .. "\n"

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -10, 0, 75)
    frame.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    frame.BorderSizePixel = 0
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)
    
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, -10, 0, 20)
    title.Position = UDim2.new(0, 5, 0, 5)
    title.BackgroundTransparency = 1
    title.Text = "Layer " .. layerNum .. " : [" .. obj.ClassName .. "] " .. obj.Name
    title.TextColor3 = obj:IsA("GuiButton") and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(255, 200, 100)
    title.Font = Enum.Font.GothamBold
    title.TextSize = 12
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.Parent = frame
    
    local pathDisplay = Instance.new("TextLabel")
    pathDisplay.Size = UDim2.new(0.7, 0, 0, 40)
    pathDisplay.Position = UDim2.new(0, 5, 0, 25)
    pathDisplay.BackgroundTransparency = 1
    pathDisplay.Text = fullPathText
    pathDisplay.TextColor3 = Color3.fromRGB(200, 200, 200)
    pathDisplay.Font = Enum.Font.Code
    pathDisplay.TextSize = 10
    pathDisplay.TextXAlignment = Enum.TextXAlignment.Left
    pathDisplay.TextYAlignment = Enum.TextYAlignment.Top
    pathDisplay.TextWrapped = true
    pathDisplay.Parent = frame
    
    local copyBtn = Instance.new("TextButton")
    copyBtn.Size = UDim2.new(0.25, 0, 0, 25)
    copyBtn.Position = UDim2.new(0.72, 0, 0, 30)
    copyBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 200)
    copyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    copyBtn.Font = Enum.Font.GothamBold
    copyBtn.TextSize = 11
    copyBtn.Text = "Copy Path"
    Instance.new("UICorner", copyBtn).CornerRadius = UDim.new(0, 4)
    copyBtn.Parent = frame
    
    copyBtn.MouseButton1Click:Connect(function()
        if pcall(function() setclipboard(fullPathText) end) then flashButton(copyBtn, "Copied!") end
    end)
    frame.Parent = ResultsScroll
end

RepeatBtn.MouseButton1Click:Connect(function()
    if lastScanX == 0 and lastScanY == 0 then
        flashButton(RepeatBtn, "No UI Scanned!", Color3.fromRGB(200, 80, 80))
        return
    end
    -- VIM menembak murni di titik pixel terakhir kali mouse diklik
    VirtualInputManager:SendMouseButtonEvent(lastScanX, lastScanY, 0, true, game, 1) 
    task.wait(0.05)
    VirtualInputManager:SendMouseButtonEvent(lastScanX, lastScanY, 0, false, game, 1) 
    flashButton(RepeatBtn, "Pixel Perfect Click!", Color3.fromRGB(50, 200, 50))
end)

if _G.UIClickDebuggerConnection then _G.UIClickDebuggerConnection:Disconnect() end
_G.UIClickDebuggerConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not isScanning then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        lastScanX, lastScanY = input.Position.X, input.Position.Y
        local guiObjects = playerGui:GetGuiObjectsAtPosition(lastScanX, lastScanY)
        
        if #guiObjects > 0 then
            allResultsData = ""
            for _, child in ipairs(ResultsScroll:GetChildren()) do if child:IsA("Frame") then child:Destroy() end end
            
            local count = 0
            for i, obj in ipairs(guiObjects) do
                if not obj:IsDescendantOf(ScreenGui) then
                    count = count + 1
                    createResultFrame(count, obj)
                end
            end
            
            isScanning = false
            ToggleScannerBtn.Text = "Scanner Status: OFF"
            ToggleScannerBtn.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
        end
    end
end)
