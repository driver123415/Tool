-- ==========================================
local espEnabled = true
local function updateESP()
	for _, p in pairs(Players:GetPlayers()) do
		if p ~= Lr and p.Character then
			local hl = p.Character:FindFirstChild("BasicGUI_ESP")
			local bgui = p.Character:FindFirstChild("BasicGUI_NameESP")
			
			if espEnabled then
				if not hl then
					hl = Instance.new("Highlight")
					hl.Name = "BasicGUI_ESP"
					hl.FillColor = Color3.new(1, 0, 0)
					hl.FillTransparency = 0.5
					hl.OutlineColor = Color3.new(1, 1, 1)
					hl.Parent = p.Character
				end
				if not bgui and p.Character:FindFirstChild("Head") then
					bgui = Instance.new("BillboardGui")
					bgui.Name = "BasicGUI_NameESP"
					bgui.Adornee = p.Character.Head
					bgui.Size = UDim2.new(0, 150, 0, 40)
					bgui.StudsOffset = Vector3.new(0, 2.5, 0)
					bgui.AlwaysOnTop = true
					
					local txt = Instance.new("TextLabel")
					txt.Parent = bgui
					txt.BackgroundTransparency = 1
					txt.Size = UDim2.new(1, 0, 1, 0)
					txt.Text = p.Name
					txt.TextColor3 = Color3.new(1, 1, 1)
					txt.TextStrokeTransparency = 0.2
					txt.Font = Enum.Font.GothamBold
					txt.TextSize = 14
					
					bgui.Parent = p.Character
				end
			else
				if hl then hl:Destroy() end
				if bgui then bgui:Destroy() end
			end
		end
	end
end

Players.PlayerAdded:Connect(function(p)
	p.CharacterAdded:Connect(function()
		task.wait(1)
		updateESP()
	end)
end)

createToggle("ESP Players & Name", true, function(state)
	espEnabled = state
	updateESP()
end)
task.spawn(updateESP)

