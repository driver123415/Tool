local function clearMonsterESP()
    local map = getMap()
    if map and map:FindFirstChild("Monsters") then
        for _, monster in pairs(map.Monsters:GetChildren()) do
            if monster:FindFirstChild("MonsterESP") then monster.MonsterESP:Destroy() end
            if monster:FindFirstChild("MonsterText") then monster.MonsterText:Destroy() end
        end
    end
end

local function clearGeneratorESP()
    local map = getMap()
    if map and map:FindFirstChild("Generators") then
        for _, gen in pairs(map.Generators:GetChildren()) do
            if gen:FindFirstChild("GenESP") then gen.GenESP:Destroy() end
            if gen:FindFirstChild("GenText") then gen.GenText:Destroy() end
        end
    end
end

local function updateMonsterESP()
    if not Config.MonsterESP.Enable then clearMonsterESP() return end
    local map = getMap()
    if not map then return end
    local monstersFolder = map:FindFirstChild("Monsters")
    if monstersFolder then
        for _, monster in pairs(monstersFolder:GetChildren()) do
            if monster:IsA("Model") and monster.PrimaryPart then
                local highlight = monster:FindFirstChild("MonsterESP")
                if not highlight then
                    highlight = Instance.new("Highlight", monster)
                    highlight.Name = "MonsterESP"
                    highlight.FillColor = Config.MonsterESP.Color
                    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                    highlight.FillTransparency = 0.5
                end
                
                local billboard = monster:FindFirstChild("MonsterText")
                local label
                if not billboard then
                    billboard = Instance.new("BillboardGui", monster)
                    billboard.Name = "MonsterText"
                    billboard.Size = UDim2.new(0, 150, 0, 50)
                    billboard.AlwaysOnTop = true
                    billboard.Adornee = monster.PrimaryPart
                    
                    label = Instance.new("TextLabel", billboard)
                    label.Name = "Text"
                    label.Size = UDim2.new(1, 0, 1, 0)
                    label.BackgroundTransparency = 1
                    label.Font = Enum.Font.Nunito
                    label.TextColor3 = Config.MonsterESP.Color
                    label.TextStrokeTransparency = 0.5
                    label.TextSize = 14
                else label = billboard:FindFirstChild("Text") end
                
                if label then label.Text = "[MONSTER]\n" .. monster.Name end
            end
        end
    end
end

