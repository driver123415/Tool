-- ==================== PROGRESS & THREATS ====================
local function isThreatened(targetPosition, radius)
    local isEvasionCheck = rootPart and (targetPosition - rootPart.Position).Magnitude <= 5

    if Config.Teleport.SuperSafeMonsterDetect and isEvasionCheck then
        local pGui = player:FindFirstChild("PlayerGui")
        local screenGui = pGui and pGui:FindFirstChild("ScreenGui")
        local monsterIcon = screenGui and screenGui:FindFirstChild("MonsterIcon")
        if monsterIcon and type(monsterIcon.ImageTransparency) == "number" then
            if monsterIcon.ImageTransparency < 0.99 then return true end
        end
    end

    local map = getMap()
    if map then
        local monstersFolder = map:FindFirstChild("Monsters")
        if monstersFolder then
            for _, monster in pairs(monstersFolder:GetChildren()) do
                if monster:FindFirstChild("ChasingValue") and monster.ChasingValue.Value == character then return true end
                
                if monster:IsA("Model") and monster.PrimaryPart then
                    local distance = (monster.PrimaryPart.Position - targetPosition).Magnitude
                    local isLethal = false
                    for _, lethalName in ipairs(Config.Teleport.AvoidmoreradiusMonsters) do
                        if monster.Name == lethalName then isLethal = true break end
                    end
                    if isLethal then
                        if distance <= Config.Teleport.LethalRadius then return true end
                        continue 
                    end
                    
                    local isLooseMonster = false
                    for _, looseName in ipairs(Config.Teleport.LooseMonsters) do
                        if monster.Name == looseName then isLooseMonster = true break end
                    end
                    if isLooseMonster then
                        if distance <= Config.Teleport.LooseRadius then return true end
                    else
                        if distance <= radius then return true end
                    end
                end
            end
        end
    end
    return false
end

local function getMachineProgress()
    local pGui = player:FindFirstChild("PlayerGui")
    if pGui then
        local specGui = pGui:FindFirstChild("SpectatorGui")
        if specGui then
            local info = specGui:FindFirstChild("InfoFrame")
            if info then
                local genFrame = info:FindFirstChild("GeneratorFrame")
                if genFrame then
                    local msg = genFrame:FindFirstChild("Message")
                    if msg and msg:IsA("TextLabel") then
                        local cur, tot = string.match(msg.Text, "Machines Completed: (%d+)/(%d+)")
                        if cur and tot then return tonumber(cur), tonumber(tot) end
                    end
                end
            end
        end
    end
    return -1, -1
end

local function isInteractingUI()
    local playerGui = player:FindFirstChild("PlayerGui")
    if playerGui then
        local screenGui = playerGui:FindFirstChild("ScreenGui")
        if screenGui then
            local menu = screenGui:FindFirstChild("Menu")
            if menu and menu:FindFirstChild("StopGenerator") and menu.StopGenerator.Visible then
                return true
            end
        end
        local clientUI = playerGui:FindFirstChild("ClientUI")
        if clientUI and clientUI:FindFirstChild("GameWindow") and clientUI.GameWindow.Visible then
            return true
        end
    end
    return false
end

local function isTrinketActive()
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return false end
    
    local trinketsUI = playerGui:FindFirstChild("ScreenGui")
        and playerGui.ScreenGui:FindFirstChild("Menu")
        and playerGui.ScreenGui.Menu:FindFirstChild("BottomLeftCorner")
        and playerGui.ScreenGui.Menu.BottomLeftCorner:FindFirstChild("Trinkets")
        
    if trinketsUI then
        for i = 1, 2 do
            local slot = trinketsUI:FindFirstChild("TrinketSlot" .. i)
            if slot then
                local textLabel = slot:FindFirstChild("TextLabel")
                if textLabel and textLabel.Text == "Active" then return true end
            end
        end
    end
    return false
end

local function isMachineOccupied(generator, radius)
    local inGamePlayers = Workspace:FindFirstChild("InGamePlayers")
    if inGamePlayers then
        for _, otherPlayer in ipairs(inGamePlayers:GetChildren()) do
            if otherPlayer.Name ~= player.Name then
                local otherRoot = otherPlayer:FindFirstChild("HumanoidRootPart")
                if otherRoot and generator.PrimaryPart then
                    if (otherRoot.Position - generator.PrimaryPart.Position).Magnitude <= radius then return true end
                end
            end
        end
    end
    return false
end

local function forceTriggerGenerator(generator)
    for _, descendant in ipairs(generator:GetDescendants()) do
        if descendant:IsA("ProximityPrompt") then
            descendant.RequiresLineOfSight = false
            descendant.MaxActivationDistance = math.huge 
            if fireproximityprompt then fireproximityprompt(descendant, 1)
            else pcall(function() descendant:InputHoldBegin() end) end
            return true
        end
    end
    return false
end

local function moveToPositionGen(targetCFrame, usePlatform)
    local originalGravity = Workspace.Gravity
    Workspace.Gravity = 0
    rootPart.AssemblyLinearVelocity = Vector3.zero
    rootPart.Anchored = false
    
    if Config.Teleport.Mode == "Instant" then
        rootPart.CFrame = targetCFrame
        task.wait(0.05) 
    else
        local speed = player:GetAttribute("KM_MAX_PLAYER_SPEED") or 16
        local distance = (rootPart.Position - targetCFrame.Position).Magnitude
        local duration = distance / (speed * Config.Teleport.TweenSpeed)
        if duration <= 0 then duration = 0.1 end
        local tween = TweenService:Create(rootPart, TweenInfo.new(duration, Enum.EasingStyle.Linear), { CFrame = targetCFrame })
        tween:Play()
        tween.Completed:Wait()
    end
    
    if usePlatform then rootPart.CFrame = targetCFrame rootPart.Anchored = true end
    Workspace.Gravity = originalGravity
end

local function getRealElevatorCFrame()
    local elevatorsFolder = Workspace:FindFirstChild("Elevators")
    if elevatorsFolder then
        for _, obj in ipairs(elevatorsFolder:GetChildren()) do
            if obj.Name == "Elevator" and obj:IsA("Model") then
                if obj.PrimaryPart then return obj.PrimaryPart.CFrame * CFrame.new(0, 3, 0)
                else
                    local centerPos = getModelCenter(obj)
                    if centerPos then return CFrame.new(centerPos) * CFrame.new(0, 3, 0) end
                end
            end
        end
        for _, obj in ipairs(elevatorsFolder:GetDescendants()) do
            if obj.Name == "ElevatorPrompt" and obj:IsA("BasePart") then return obj.CFrame * CFrame.new(0, 1.5, 2) end
        end
    end
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj.Name == "ElevatorPrompt" and obj:IsA("BasePart") then
            local parentName = string.lower(obj.Parent and obj.Parent.Name or "")
            if not string.find(parentName, "fake") then return obj.CFrame * CFrame.new(0, 1.5, 2) end
        end
    end
    return nil
end

