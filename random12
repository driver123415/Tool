local isMinimized = false

minimizeBtn.MouseButton1Click:Connect(function()
    isMinimized = not isMinimized
    if isMinimized then
        mainFrame.Size = UDim2.new(0, 180, 0, 25)
        toggleBtn.Visible = false 
        safePlaceBtn.Visible = false
        barnabyBtn.Visible = false 
        espMonsterBtn.Visible = false 
        espMachineBtn.Visible = false
    else
        mainFrame.Size = UDim2.new(0, 180, 0, 245)
        toggleBtn.Visible = true 
        safePlaceBtn.Visible = true
        barnabyBtn.Visible = true 
        espMonsterBtn.Visible = true 
        espMachineBtn.Visible = true
    end
end)

closeBtn.MouseButton1Click:Connect(function()
    _G.AkbarAutoFarmRunning = false
    isMasterFarming = false
    Config.SafePlace = false
    Config.BarnabyAutoWin = false
    Config.MonsterESP.Enable = false 
    Config.GenESP.Enable = false
    task.wait(0.1)
    clearMonsterESP() clearGeneratorESP()
    if rootPart then rootPart.Anchored = false end
    forceStop()
    screenGui:Destroy()
end)

toggleBtn.MouseButton1Click:Connect(function()
    if isMasterFarming then
        isMasterFarming = false
        if rootPart then rootPart.Anchored = false end
        forceStop() 
        toggleBtn.Text = "START FARM" toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    else
        isMasterFarming = true
        toggleBtn.Text = "STOP FARM" toggleBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
        startAutoFarming()
    end
end)

safePlaceBtn.MouseButton1Click:Connect(function()
    Config.SafePlace = not Config.SafePlace
    if Config.SafePlace then
        safePlaceBtn.Text = "SAFE PLACE: ON"
        safePlaceBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 200) -- Warna biru pembeda
    else
        safePlaceBtn.Text = "SAFE PLACE: OFF"
        safePlaceBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    end
end)

barnabyBtn.MouseButton1Click:Connect(function()
