local function startAutoFarming()
    local inElevatorStandby = false

    task.spawn(function()
        while _G.AkbarAutoFarmRunning do
            pcall(function()
                local events = ReplicatedStorage:FindFirstChild("Events")
                local su = events and events:FindFirstChild("SkillcheckUpdate")
                
                if su then
                    if isMasterFarming then
                        if su.OnClientInvoke and not originalSkillcheck then
                            originalSkillcheck = su.OnClientInvoke
                        end
                        su.OnClientInvoke = function() return true end
                    else
                        if originalSkillcheck then
                            su.OnClientInvoke = originalSkillcheck
                            originalSkillcheck = nil
                        end
                    end
                end
            end)
            task.wait(1)
        end
    end)

    task.spawn(function()
        while isMasterFarming and _G.AkbarAutoFarmRunning do
            character = player.Character or player.CharacterAdded:Wait()
            rootPart = character:WaitForChild("HumanoidRootPart")

            local map = getMap()
            if map then
                local genFolder = map:FindFirstChild("Generators")
                if genFolder then
                    
                    local targetGen = nil
                    local uncompletedCount = 0
                    local anyEmptyGen = nil
                    
                    for _, gen in pairs(genFolder:GetChildren()) do
                        if gen:IsA("Model") and gen.PrimaryPart then
                            local stats = gen:FindFirstChild("Stats")
                            if stats then
                                local completed = stats:FindFirstChild("Completed") and stats.Completed.Value
                                local connie = stats:FindFirstChild("Connie") and stats.Connie.Value
                                
                                if not completed then
                                    uncompletedCount = uncompletedCount + 1
                                    if not connie then
                                        if not isThreatened(gen.PrimaryPart.Position, Config.Teleport.SafeRadius + 15) then
                                            if not isMachineOccupied(gen, Config.Teleport.PlayerRadius) then
                                                if not anyEmptyGen then anyEmptyGen = gen end
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end
                    
                    targetGen = anyEmptyGen 
                    
                    local curGenUI, totGenUI = getMachineProgress()
                    local isFloorActuallyDone = false
                    
                    if curGenUI ~= -1 and totGenUI ~= -1 then isFloorActuallyDone = (curGenUI >= totGenUI)
                    else isFloorActuallyDone = (uncompletedCount == 0) end
                    
                    if isFloorActuallyDone then
                        if not inElevatorStandby then inElevatorStandby = true end
                        local elevatorTarget = getRealElevatorCFrame()
                        if elevatorTarget then
                            local dist = (rootPart.Position - elevatorTarget.Position).Magnitude
                            if dist > 7 then moveToPositionGen(elevatorTarget, true)
                            else if rootPart.Anchored then rootPart.Anchored = false end end
                        end
                        task.wait(0.5) 
                        
                    elseif targetGen then
                        inElevatorStandby = false
                        local centerPos = getModelCenter(targetGen)
                        if centerPos and targetGen.PrimaryPart then
                            local targetCFrame = CFrame.new(centerPos.X, targetGen.PrimaryPart.Position.Y + Config.Teleport.UndergroundOffset, centerPos.Z)
                            moveToPositionGen(targetCFrame, true)
                            
                            local isContested = false
                            local monsterEvade = false
                            local needSync = isTrinketActive()
                            
                            if needSync then
                                local minD = Config.Teleport.SyncDelayMin
                                local maxD = Config.Teleport.SyncDelayMax
                                local syncDelay = minD + (math.random() * (maxD - minD))
                                
                                local elapsed = 0
                                while elapsed < syncDelay do
                                    if isThreatened(rootPart.Position, Config.Teleport.SafeRadius) then
                                        monsterEvade = true break
                                    end
                                    task.wait(0.1)
                                    elapsed = elapsed + 0.1
                                end
                                if not monsterEvade and isMachineOccupied(targetGen, Config.Teleport.PlayerRadius) then isContested = true end
                            else
                                if isThreatened(rootPart.Position, Config.Teleport.SafeRadius) then monsterEvade = true
                                elseif isMachineOccupied(targetGen, Config.Teleport.PlayerRadius) then isContested = true end
                            end
                            
                            if monsterEvade then
                                rootPart.Anchored = false
                                local safePos = getSafePlaceCFrame()
                                if safePos then teleportplr(safePos) else teleportplr(rootPart.CFrame * CFrame.new(0, 50, 0)) end
                                task.wait(1.5)
                            elseif isContested then
                                rootPart.Anchored = false
                            else
                                local hasStartedInteracting = false
                                local instantNext = false
                                local failTimer = 0 
                                
                                while isMasterFarming and _G.AkbarAutoFarmRunning do
                                    if not targetGen.Parent then break end

                                    local stats = targetGen:FindFirstChild("Stats")
                                    if stats and stats:FindFirstChild("Completed") and stats.Completed.Value then
                                        instantNext = true break 
                                    end
                                    
                                    if isThreatened(rootPart.Position, Config.Teleport.SafeRadius) then
                                        forceStop() rootPart.Anchored = false
                                        local safePos = getSafePlaceCFrame()
                                        if safePos then teleportplr(safePos) else teleportplr(rootPart.CFrame * CFrame.new(0, 50, 0)) end
                                        instantNext = true break
                                    end
                                    
                                    if isMachineOccupied(targetGen, Config.Teleport.PlayerRadius) then
                                        forceStop() task.wait(0.1) instantNext = true break
                                    end
                                    
                                    local currentlyInteracting = isInteractingUI()
                                    
                                    -- [LOGIKA SAFE PLACE EXTRACTING]
                                    if currentlyInteracting and Config.SafePlace then
                                        local safePos = getSafePlaceCFrame()
                                        if safePos then
                                            rootPart.CFrame = safePos
                                        else
                                            -- Backup jika map tidak ada tempat aman
                                            rootPart.CFrame = targetCFrame * CFrame.new(0, 50, 0)
                                        end
                                    else
                                        -- Jika tidak nyala atau belum extracting, diam di mesin
                                        rootPart.CFrame = targetCFrame
                                    end

                                    if currentlyInteracting then
                                        hasStartedInteracting = true
                                        failTimer = 0 
                                    elseif hasStartedInteracting and not currentlyInteracting then
                                        forceStop() instantNext = true break
                                    else
                                        forceTriggerGenerator(targetGen)
                                        failTimer = failTimer + 1
                                        if failTimer == 10 then
                                            -- Hanya goyangkan posisi jika dia BELUM di safe place
                                            if not (currentlyInteracting and Config.SafePlace) then
                                                rootPart.CFrame = targetCFrame * CFrame.new(0, 1.5, 0)
                                                task.wait(0.1)
                                                rootPart.CFrame = targetCFrame
                                            end
                                        elseif failTimer >= 25 then
                                            forceStop() instantNext = true break
                                        end
                                    end
                                    task.wait(0.1)
                                end
                                
                                rootPart.Anchored = false
                                if instantNext then task.wait(0.05) else task.wait(Config.Teleport.DelayNext) end
                            end
                        end
                    else
                        rootPart.Anchored = false
                        local safePos = getSafePlaceCFrame()
                        if safePos then teleportplr(safePos) end
                        task.wait(1) 
                    end
                end
            end
            task.wait(0.1)
        end
    end)
end

