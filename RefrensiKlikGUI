-- === GENERATED VIM AUTO-CLICK SCRIPT ===
local VirtualInputManager = game:GetService("VirtualInputManager")
local GuiService = game:GetService("GuiService")

local function AutoClickUI(buttonObj, offsetX, offsetY)
    if not buttonObj or not buttonObj.Parent then 
        warn("Tombol tidak ditemukan / belum di-render!")
        return 
    end
    
    local screenGui = buttonObj:FindFirstAncestorOfClass("ScreenGui")
    local insetX, insetY = 0, 0
    if screenGui and not screenGui.IgnoreGuiInset then
        local insetTopLeft = GuiService:GetGuiInset()
        insetX, insetY = insetTopLeft.X, insetTopLeft.Y
    end
    
    local centerX = buttonObj.AbsolutePosition.X + (buttonObj.AbsoluteSize.X / 2) + insetX + offsetX
    local centerY = buttonObj.AbsolutePosition.Y + (buttonObj.AbsoluteSize.Y / 2) + insetY + offsetY

    VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, true, game, 1)
    task.wait(0.05)
    VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, false, game, 1)
end

