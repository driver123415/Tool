-- Method 17: ⚡ PALING OP — Gabungan + Retry otomatis
-- ==============================
local btn = Players.dandilur123.PlayerGui.GameGuiNoInset.Screen.Top.WaveControls.AutoSkip

local function superClick()
    -- Layer 1: firesignal semua event
    local events = {"Activated","MouseButton1Click","MouseButton1Down","MouseButton1Up","SelectionGained"}
    for _, e in ipairs(events) do
        pcall(function() firesignal(btn[e]) end)
    end

    -- Layer 2: getconnections
    for _, e in ipairs(events) do
        pcall(function()
            for _, c in next, getconnections(btn[e]) do c:Fire() end
        end)
    end

    -- Layer 3: VirtualUser
    pcall(function()
        local vu = game:GetService("VirtualUser")
        local pos = btn.AbsolutePosition + (btn.AbsoluteSize / 2)
        vu:Button1Down(pos, workspace.CurrentCamera.CFrame)
        task.wait(0.05)
        vu:Button1Up(pos, workspace.CurrentCamera.CFrame)
    end)

    -- Layer 4: mouse functions
    pcall(function()
        local pos = btn.AbsolutePosition + (btn.AbsoluteSize / 2)
        mousemoveabs(pos.X, pos.Y)
        task.wait(0.05)
        mouse1press()
        task.wait(0.05)
        mouse1release()
    end)

    -- Layer 5: Force visible & active
    pcall(function()
        btn.Visible = true
        btn.Active = true
        btn.Selectable = true
    end)
end

-- Retry 5x sampai berhasil
for i = 1, 5 do
    task.wait(1)
    superClick()
    print("Attempt:", i)
end
print("Method 17 - SUPER CLICK selesai")


